{
  "name": "@ddrayne/openclaw-modue-bridge",
  "version": "0.1.0",
  "description": "Community OpenClaw bridge that registers modue.* RPC relays so the Modue plugin can talk to OpenClaw agents.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "node --test 'test/**/*.test.js'"
  },
  "openclaw": {
    "extensions": ["./index.js"],
    "plugin": {
      "id": "ddrayne-modue-bridge"
    },
    "install": {
      "npmSpec": "@ddrayne/openclaw-modue-bridge"
    }
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "modue",
    "control-surface"
  ],
  "author": "ddrayne",
  "license": "ISC",
  "homepage": "https://github.com/ddrayne/openclaw-modue-bridge",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ddrayne/openclaw-modue-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/ddrayne/openclaw-modue-bridge/issues"
  }
}
